rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAccountMember(accountId) {
      return request.auth != null &&
             request.auth.token.accountId == accountId;
    }

    function isAccountAdmin(accountId) {
      return isAccountMember(accountId) &&
             request.auth.token.role in ["owner", "admin"];
    }

    match /accounts/{accountId} {
      allow read: if isAccountMember(accountId);
      allow write: if isAccountAdmin(accountId);

      match /members/{uid} {
        allow read: if isAccountMember(accountId);
        allow write: if false;
      }

      // Customers are written ONLY through the createCustomer/updateCustomer
      // callables (Admin SDK, which bypasses these Rules), so those callables are
      // the Rules-enforced single write path and the schema factories are the one
      // true validator (SECURITY: S2). Clients may read live via onSnapshot but
      // cannot write around the validator. Mirrors the jobs/members posture.
      match /customers/{customerId} {
        allow read: if isAccountMember(accountId);
        allow write: if false;
      }

      match /phoneSettings/{settingId} {
        allow read, write: if isAccountMember(accountId);
      }

      match /calls/{callId} {
        allow read, write: if isAccountMember(accountId);
      }

      match /phonePlaybook/{docId} {
        allow read: if isAccountMember(accountId);
        allow write: if false;
      }

      // Jobs are written ONLY through the createJob/updateJob callables (Admin SDK,
      // which bypasses these Rules). Clients may read the board live via onSnapshot,
      // but cannot write around the validator — the callable is the Rules-enforced
      // single write path (SECURITY: S2). Mirrors the members/phonePlaybook posture.
      match /jobs/{jobId} {
        allow read: if isAccountMember(accountId);
        allow write: if false;
      }
    }

    match /invites/{inviteId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['email', 'accountId', 'role', 'status', 'createdAt', 'invitedBy'])
        && request.resource.data.accountId is string
        && exists(/databases/$(database)/documents/accounts/$(request.resource.data.accountId)/members/$(request.auth.uid))
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.role in ['member', 'admin'];

      allow read, update, delete: if false;
    }

    // SMS consent records, captured pre-account on the public marketing site and
    // written ONLY through the submitSmsOptin function (Admin SDK bypasses these
    // Rules). This is consent PII / Twilio verification evidence — no client may
    // read or write it. Mirrors the members/customers/jobs server-only posture.
    match /smsOptins/{phoneDigits} {
      allow read, write: if false;
    }
  }
}
